{
  "name": "chair-rental-api",
  "version": "1.0.0",
  "description": "Chair rental multi-tenant API",
  "author": "",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "nest build",
    "start": "node dist/src/main.js",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/src/main.js",
    "typeorm": "node ./node_modules/typeorm/cli.js",
    "db:show": "npm run typeorm -- migration:show -d dist/src/database/data-source.js",
    "db:migrate": "npm run typeorm -- migration:run -d dist/src/database/data-source.js",
    "db:revert": "npm run typeorm -- migration:revert -d dist/src/database/data-source.js",
    "migration:run": "npm run build && node ./node_modules/typeorm/cli.js migration:run -d dist/src/database/data-source.js",
    "migration:revert": "node ./node_modules/typeorm/cli.js migration:revert -d dist/src/database/data-source.js",
    "seed:catalog": "node dist/src/scripts/seed-catalog.js",
    "seed:master": "node dist/src/scripts/seed-master-data.js",
    "seed:vendors": "node dist/src/scripts/seed-vendor-distance.js",
    "seed:test-vendors": "node dist/src/scripts/seed-test-vendors.js",
    "seed:all": "npm run seed:catalog && npm run seed:master && npm run seed:vendors && npm run seed:test-vendors",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/serve-static": "^4.0.2",
    "@nestjs/swagger": "^7.3.0",
    "@nestjs/typeorm": "^10.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "date-fns": "^3.3.1",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.9.1",
    "nodemailer": "^8.0.2",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/testing": "^10.4.20",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.16",
    "@types/nodemailer": "^7.0.11",
    "@types/passport-google-oauth20": "^2.0.14",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^9.0.8",
    "@vitest/coverage-v8": "^1.6.0",
    "supertest": "^7.1.1",
    "typescript": "^5.3.3",
    "vitest": "^1.6.0"
  }
}
